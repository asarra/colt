variant: fcos
version: 1.7.0
passwd:
  users:
    - name: core
      ssh_authorized_keys:
        - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIMZRe2aijb9MoKGs8EsEnjxRoelpbupUFVzn1Re45wkT nix@bazzite

storage:
  directories:
    - path: /var/srv
      mode: 0755
    - path: /etc/ucore-autorebase
      mode: 0754
  files:
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: colt
    - path: /etc/containers/systemd/homelab-stack.yaml
      mode: 0644
      contents:
        source: https://raw.githubusercontent.com/asarra/colt/refs/heads/main/homelab-stack.yaml

systemd:
  units:
    - name: ucore-unsigned-autorebase.service
      enabled: true
      contents: |
        [Unit]
        Description=uCore autorebase to unsigned OCI and reboot
        ConditionPathExists=!/etc/ucore-autorebase/unverified
        ConditionPathExists=!/etc/ucore-autorebase/signed
        After=network-online.target
        Wants=network-online.target
        [Service]
        Type=oneshot
        StandardOutput=journal+console
        ExecStart=/usr/bin/rpm-ostree rebase --bypass-driver ostree-unverified-registry:ghcr.io/ublue-os/ucore-minimal:stable-nvidia-lts
        ExecStart=/usr/bin/touch /etc/ucore-autorebase/unverified
        ExecStart=/usr/bin/systemctl disable ucore-unsigned-autorebase.service
        ExecStart=/usr/bin/systemctl reboot
        [Install]
        WantedBy=multi-user.target
    - name: ucore-signed-autorebase.service
      enabled: true
      contents: |
        [Unit]
        Description=uCore autorebase to signed OCI and reboot
        ConditionPathExists=/etc/ucore-autorebase/unverified
        ConditionPathExists=!/etc/ucore-autorebase/signed
        After=network-online.target
        Wants=network-online.target
        [Service]
        Type=oneshot
        StandardOutput=journal+console
        ExecStart=/usr/bin/rpm-ostree rebase --bypass-driver ostree-image-signed:docker://ghcr.io/ublue-os/ucore-minimal:stable-nvidia-lts
        ExecStart=/usr/bin/touch /etc/ucore-autorebase/signed
        ExecStart=/usr/bin/systemctl disable ucore-signed-autorebase.service
        ExecStart=/usr/bin/systemctl reboot
        [Install]
        WantedBy=multi-user.target
    - name: homelab-docker.service
      enabled: true
      contents: |
        [Unit]
        After=docker.service network-online.target
        Requires=docker.service
        ConditionPathExists=/etc/ucore-autorebase/signed
        [Service]
        Type=oneshot
        RemainAfterExit=yes
        ExecStartPre=/usr/bin/bash -c '/usr/bin/mkdir -p /var/srv/{ollama,searxng,chromadb,vaultwarden,forgejo,media,uptime-kuma,stirling-pdf} /var/srv/jellyfin/{config,cache} /var/srv/ntfy/cache /var/srv/odysseus/logs /var/srv/odysseus/data/{ssh,huggingface,local}'
        ExecStartPre=/usr/bin/bash -c '/usr/bin/chown -R core:core /var/srv && /usr/bin/chown -R 1002:1002 /var/srv/vaultwarden && /usr/bin/chown -R 1003:1003 /var/srv/forgejo && /usr/bin/chown -R 1004:1004 /var/srv/{jellyfin,media}'
        ExecStartPre=/usr/bin/chcon -Rt svirt_sandbox_file_t /var/srv
        ExecStart=/usr/bin/docker compose -f /etc/containers/systemd/homelab-stack.yaml up -d
        ExecStop=/usr/bin/docker compose -f /etc/containers/systemd/homelab-stack.yaml down
        [Install]
        WantedBy=multi-user.target
    - name: tailscale-serve.service
      enabled: false
      contents: |
        [Unit]
        After=homelab-docker.service network-online.target
        Requires=homelab-docker.service
        ConditionPathExists=/etc/ucore-autorebase/signed
        [Service]
        Type=oneshot
        RemainAfterExit=yes
        StandardOutput=journal+console
        # Vaultwarden needs HTTPS to function
        ExecStart=/usr/bin/tailscale serve --bg --https=443 http://127.0.0.1:8001
        # We will use TCP forwards to not break subpaths
        ExecStart=/usr/bin/tailscale serve --bg --tcp=3000 3000
        ExecStart=/usr/bin/tailscale serve --bg --tcp=222 222
        ExecStart=/usr/bin/tailscale serve --bg --tcp=8091 8091
        ExecStart=/usr/bin/tailscale serve --bg --tcp=7000 7000
        ExecStart=/usr/bin/tailscale serve --bg --tcp=8100 8100
        ExecStart=/usr/bin/tailscale serve --bg --tcp=8080 8080
        ExecStart=/usr/bin/tailscale serve --bg --tcp=11434 11434
        ExecStart=/usr/bin/tailscale serve --bg --tcp=8096 8096
        ExecStart=/usr/bin/tailscale serve --bg --tcp=3001 3001
        ExecStart=/usr/bin/tailscale serve --bg --tcp=8083 8083
        ExecStop=/usr/bin/tailscale serve reset
        [Install]
        WantedBy=multi-user.target
